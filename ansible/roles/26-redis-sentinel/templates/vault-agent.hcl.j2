pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr | trim('/') }}"
  ca_cert = "/etc/vault.d/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path }}"
    config = {
      role_id_file_path = "/etc/vault.d/approle/role_id"
      secret_id_file_path = "/etc/vault.d/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Server Certificate, Key & CA Bundle Template
template {
  destination = "/tmp/cert-bundle.json"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ hostvars[inventory_hostname]['advertise_ip'] ~ ',' ~ redis_ha_virtual_ip ~ '" "ttl=' ~ (vault_agent_cert_ttl | default('24h')) ~ '" -}}' }}
{{ '{{ .Data | toJSON }}' }}
{{ '{{- end -}}' }}
EOH

  command = "/bin/sh -c \"jq -r '.certificate' /tmp/cert-bundle.json > /etc/redis/certs/server.crt && jq -r '.private_key' /tmp/cert-bundle.json > /etc/redis/certs/server.key && jq -r '.issuing_ca' /tmp/cert-bundle.json > /etc/redis/certs/ca.crt && chown redis:redis /etc/redis/certs/* && chmod 0644 /etc/redis/certs/*.crt && chmod 0600 /etc/redis/certs/server.key && systemctl restart redis-server && (systemctl is-active --quiet redis-sentinel && systemctl restart redis-sentinel || true)\""
}
