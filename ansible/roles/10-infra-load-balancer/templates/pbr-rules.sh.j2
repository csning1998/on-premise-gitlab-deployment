#!/bin/bash

set -e

# 0. Global Preference: Treat all internal 172.16.0.0/16 traffic via main table
#    This prevents source-based routing from forcing internal replies out through gateways,
#    ensuring symmetric L2 traffic between internal segments.
ip rule del to 172.16.0.0/16 lookup main priority 200 2>/dev/null || true
ip rule add to 172.16.0.0/16 lookup main priority 200

# 1. Inject each VIP's dedicated table, default route, and scope link
#    ip rule del runs unconditionally to remove any stale rules from previous executions.
#    Route injection is skipped if the interface is not present on the host.
{% for seg in lb_service_segments %}
ip rule del from {{ seg.vip }} table rt_{{ seg.name | replace('-', '_') }} 2>/dev/null || true
if ip link show {{ seg.interface_alias }} &>/dev/null; then
  ip rule add from {{ seg.vip }} table rt_{{ seg.name | replace('-', '_') }} priority {{ 100 + loop.index0 }}
  ip route replace default via {{ seg.cidr | regex_replace('\\.0/24$', '.1') }} dev {{ seg.interface_alias }} table rt_{{ seg.name | replace('-', '_') }} advmss {{ global_mss }}
  ip route replace {{ seg.cidr }} dev {{ seg.interface_alias }} scope link table rt_{{ seg.name | replace('-', '_') }} advmss {{ global_mss }}
fi
{% endfor %}

# 2. Targeted L2 Return Paths for All Internal Services
#    Kubernetes and MicroK8s nodes connect to VIPs via static routes pointing to the local L2 HAProxy VIP.
#    This ensures SYN packets arrive intra-bridge, bypassing the hypervisor's FORWARD chain.
#    To prevent hypervisor conntrack or iptables from dropping return packets, the corresponding SYN-ACK
#    must also remain intra-bridge. Injecting segment scope links into all VIP routing tables ensures
#    that SYN-ACK packets exit via the same L2 bridge on which the SYN packets were received.
{% for target_seg in lb_service_segments %}
{% for source_seg in lb_service_segments %}
ip route replace {{ source_seg.cidr }} dev {{ source_seg.interface_alias }} scope link table rt_{{ target_seg.name | replace('-', '_') }} advmss {{ global_mss }} 2>/dev/null || true
{% endfor %}
{% endfor %}

# 4. Network Performance: Global Bidirectional MSS Clamping
#    Ensures stability for ALL TCP traffic (Forwarded and Local-Proxy) across virtual segments.
#    This covers both client-to-VIP and CLB-to-backend traffic.
iptables -t mangle -D POSTROUTING -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --set-mss {{ global_mss }} 2>/dev/null || true
iptables -t mangle -A POSTROUTING -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --set-mss {{ global_mss }}
