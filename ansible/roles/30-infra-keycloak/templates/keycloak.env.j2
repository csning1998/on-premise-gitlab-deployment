# Keycloak Bootstrap Credentials
KC_BOOTSTRAP_ADMIN_USERNAME={{ keycloak_admin_user }}
KC_BOOTSTRAP_ADMIN_PASSWORD={{ keycloak_admin_password }}

# Database Configuration (Internal Postgres 18)
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KC_DB_USERNAME={{ keycloak_db_user }}
KC_DB_PASSWORD={{ keycloak_db_password }}

# HTTP & Proxy Settings (L4 Passthrough Pattern)
KC_HOSTNAME={{ keycloak_fqdn }}
KC_PROXY=passthrough
KC_HTTPS_PORT=8080
KC_HTTPS_CERTIFICATE_FILE=/opt/keycloak/certs/server.crt
KC_HTTPS_CERTIFICATE_KEY_FILE=/opt/keycloak/certs/server.key

# Optimization & Production Mode
KC_HTTP_RELATIVE_PATH=/
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true
KC_MANAGEMENT_ENABLED=true
KC_MANAGEMENT_PORT=9000
KC_MANAGEMENT_PROTOCOL=https
