
pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr | trim('/') }}"

  ca_cert = "/etc/vault.d/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path | trim('/') }}"
    config = {
      role_id_file_path = "/etc/vault.d/approle/role_id"
      secret_id_file_path = "/etc/vault.d/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Separate the Data object and EOH fields onto different lines to ensure that the rendered file's EOH field is on a separate line in HCL syntax.
# Raw -> Ansible variable -> Raw

# Server Certificate, Key & CA Bundle Template
template {
  destination = "/tmp/cert-bundle.json"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ '" "ttl=' ~ (vault_agent_cert_ttl | default('24h')) ~ '" -}}' }}
{{ '{{ .Data | toJSON }}' }}
{{ '{{- end -}}' }}
EOH

  command = "/bin/sh -c \"jq -r '.certificate' /tmp/cert-bundle.json > /etc/postgresql/certs/server.crt && jq -r '.private_key' /tmp/cert-bundle.json > /etc/postgresql/certs/server.key && jq -r '.issuing_ca' /tmp/cert-bundle.json > /etc/postgresql/certs/ca.crt && chown postgres:postgres /etc/postgresql/certs/* && chmod 0644 /etc/postgresql/certs/*.crt && chmod 0600 /etc/postgresql/certs/server.key && systemctl restart patroni\""
}
