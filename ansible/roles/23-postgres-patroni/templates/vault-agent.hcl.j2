
pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr | trim('/') }}"

  ca_cert = "/etc/vault.d/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path | trim('/') }}"
    config = {
      role_id_file_path = "/etc/vault.d/approle/role_id"
      secret_id_file_path = "/etc/vault.d/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Separate the Data object and EOH fields onto different lines to ensure that the rendered file's EOH field is on a separate line in HCL syntax.
# Raw -> Ansible variable -> Raw

# Single Template producing an executable shell script.
# This prevents ALL JSON parsing dependencies and Cert/Key mismatches.
template {
  destination = "/etc/vault.d/deploy-certs.sh"
  perms       = "0700"
  contents    = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ '" "ttl=' ~ (vault_agent_cert_ttl | default('24h')) ~ '" -}}' }}
#!/bin/sh

cat << 'CERT_EOF' > /etc/postgresql/certs/server.crt
{{ '{{ .Data.certificate }}' }}
CERT_EOF

cat << 'KEY_EOF' > /etc/postgresql/certs/server.key
{{ '{{ .Data.private_key }}' }}
KEY_EOF

cat << 'CA_EOF' > /etc/postgresql/certs/ca.crt
{{ '{{ .Data.issuing_ca }}' }}
CA_EOF

chown postgres:postgres /etc/postgresql/certs/server.crt /etc/postgresql/certs/server.key /etc/postgresql/certs/ca.crt
chmod 0644 /etc/postgresql/certs/server.crt /etc/postgresql/certs/ca.crt
chmod 0600 /etc/postgresql/certs/server.key

systemctl reload patroni
{{ '{{- end -}}' }}
EOH

  command = "/bin/sh /etc/vault.d/deploy-certs.sh"
}
