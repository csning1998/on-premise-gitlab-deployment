# Standalone Praefect Node Configuration
postgresql['enable'] = false
redis['enable'] = false
nginx['enable'] = false
puma['enable'] = false
sidekiq['enable'] = false
gitlab_workhorse['enable'] = false
gitlab_exporter['enable'] = false
alertmanager['enable'] = false
prometheus['enable'] = false
registry['enable'] = false
gitaly['enable'] = false
gitlab_kas['enable'] = false

# Enable Praefect
praefect['enable'] = true

# Only the primary Praefect node (inventory group 'primary') should run DB migrations.
# Concurrent migration runs on replica nodes cause "relation already exists" errors
# because the primary node creates the schema first during the same reconfigure pass.
praefect['auto_migrate'] = {{ 'true' if inventory_hostname in (groups['primary'] | default([])) else 'false' }}

praefect['configuration'] = {
  listen_addr: '0.0.0.0:2305',
  prometheus_listen_addr: '0.0.0.0:9652',
{% if praefect_tls_enabled | default(false) %}
  tls_listen_addr: '0.0.0.0:2306',
  tls: {
    certificate_path: '/etc/gitlab/ssl/server.crt',
    key_path: '/etc/gitlab/ssl/server.key',
    client_ca_path: '/etc/gitlab/ssl/ca.crt'
  },
{% endif %}
  auth: {
    token: '{{ praefect_external_token }}'
  },
  # Database connection to the Praefect Patroni DB cluster
  database: {
    host: '{{ postgres_ha_vip }}',
    port: 5432,
    user: '{{ praefect_db_user | default("praefect") }}',
    password: '{{ praefect_db_password }}',
    dbname: '{{ praefect_db_name | default("praefect_production") }}',
    sslmode: 'verify-ca',
    sslrootcert: '/etc/gitlab/ssl/ca.crt',
    sslcert: '/etc/gitlab/ssl/server.crt',
    sslkey: '/etc/gitlab/ssl/server.key'
  },
  # Dynamic sharding to Gitaly nodes based on active inventory
  virtual_storage: [
    {
      name: '{{ praefect_virtual_storage_name | default("default") }}',
      node: [
{% for host in groups['gitaly'] %}
        {
          storage: 'gitaly-{{ loop.index0 }}',
{% if gitaly_tls_enabled | default(false) %}
          address: 'tls://{{ hostvars[host]["advertise_ip"] }}:8076',
{% else %}
          address: 'tcp://{{ hostvars[host]["advertise_ip"] }}:8075',
{% endif %}
          token: '{{ gitaly_auth_token }}'
        },
{% endfor %}
      ]
    }
  ]
}
