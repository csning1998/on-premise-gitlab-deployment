
pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr }}"
  ca_cert = "{{ vault_agent_config_dir }}/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path }}"
    config = {
      role_id_file_path = "{{ vault_agent_config_dir }}/approle/role_id"
      secret_id_file_path = "{{ vault_agent_config_dir }}/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Server Certificate, Key & CA Bundle Template
template {
  destination = "/tmp/cert-bundle.pem"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ ',' ~ dev_harbor_vip ~ '" "ttl=' ~ (vault_agent_cert_ttl | default('24h')) ~ '" -}}' }}
{{ '{{ .Data.certificate }}' }}
{{ '{{ .Data.issuing_ca }}' }}
-----SPLIT-----
{{ '{{ .Data.private_key }}' }}
-----SPLIT-----
{{ '{{ .Data.issuing_ca }}' }}
{{ '{{- end -}}' }}
EOH

  # Split bundle into separate standard files using awk, apply permissions, and trigger nginx reload
  command = "mkdir -p /data/harbor/secret/cert && awk -v RS='-----SPLIT-----\\n' 'NR==1{print > \"{{ harbor_cert_path }}\"} NR==2{print > \"{{ harbor_key_path }}\"} NR==3{print > \"{{ harbor_ca_path }}\"}' /tmp/cert-bundle.pem && chmod 600 {{ harbor_key_path }} && chmod 644 {{ harbor_ca_path }} && (docker ps -q -f name=^nginx$ | grep -q . && docker exec -i nginx nginx -s reload || true)"
}
