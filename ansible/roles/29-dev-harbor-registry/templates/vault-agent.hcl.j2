
pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr }}"
  ca_cert = "{{ vault_agent_config_dir }}/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path }}"
    config = {
      role_id_file_path = "{{ vault_agent_config_dir }}/approle/role_id"
      secret_id_file_path = "{{ vault_agent_config_dir }}/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Single Template producing an executable shell script.
# This prevents ALL JSON parsing dependencies and Cert/Key mismatches.
template {
  destination = "/etc/vault.d/deploy-certs.sh"
  perms       = "0700"
  contents    = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ ',' ~ dev_harbor_vip ~ '" "ttl=' ~ vault_agent_cert_ttl ~ '" -}}' }}
#!/bin/sh

mkdir -p "$(dirname "{{ harbor_cert_path }}")"
mkdir -p /data/harbor/secret/cert

cat << 'CERT_EOF' > {{ harbor_cert_path }}
{{ '{{ .Data.certificate }}' }}
{{ '{{ .Data.issuing_ca }}' }}
CERT_EOF

cat << 'KEY_EOF' > {{ harbor_key_path }}
{{ '{{ .Data.private_key }}' }}
KEY_EOF

cat << 'CA_EOF' > {{ harbor_ca_path }}
{{ '{{ .Data.issuing_ca }}' }}
CA_EOF

cp {{ harbor_cert_path }} /data/harbor/secret/cert/server.crt
cp {{ harbor_key_path }} /data/harbor/secret/cert/server.key

chmod 0644 {{ harbor_cert_path }} {{ harbor_ca_path }} /data/harbor/secret/cert/server.crt
chmod 0600 {{ harbor_key_path }} /data/harbor/secret/cert/server.key

docker ps -q -f name=^nginx$ | grep -q . && docker exec -i nginx nginx -s reload || true
{{ '{{- end -}}' }}
EOH

  command = "/bin/sh /etc/vault.d/deploy-certs.sh"
}
