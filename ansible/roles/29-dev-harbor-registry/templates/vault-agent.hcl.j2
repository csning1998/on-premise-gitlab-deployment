
pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr }}"
  ca_cert = "{{ vault_agent_config_dir }}/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path }}"
    config = {
      role_id_file_path = "{{ vault_agent_config_dir }}/approle/role_id"
      secret_id_file_path = "{{ vault_agent_config_dir }}/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Server Certificate & Key Template
template {
  destination = "{{ harbor_cert_path }}"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ ',' ~ dev_harbor_vip ~ '" "ttl=24h" -}}' }}
{{ '{{ .Data.certificate }}' }}
{{ '{{ .Data.issuing_ca }}' }}
{{ '{{- end -}}' }}
EOH
  # Logic: Check if harbor-nginx container is running. If yes, reload nginx. If not (first install), do nothing.
  command = "mkdir -p /data/harbor/secret/cert; cp {{ harbor_cert_path }} /data/harbor/secret/cert/server.crt 2>/dev/null || true; (docker ps -q -f name=^nginx$ | grep -q . && docker exec -i nginx nginx -s reload) || true"
}

template {
  destination = "{{ harbor_key_path }}"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ ',' ~ dev_harbor_vip ~ '" "ttl=24h" -}}' }}
{{ '{{ .Data.private_key }}' }}
{{ '{{- end -}}' }}
EOH
  command = "chmod 0600 {{ harbor_key_path }}; mkdir -p /data/harbor/secret/cert; cp {{ harbor_key_path }} /data/harbor/secret/cert/server.key 2>/dev/null || true"
}

# CA Certificate (Trust Anchor)
template {
  destination = "{{ harbor_ca_path }}"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ttl=24h" -}}' }}
{{ '{{ .Data.issuing_ca }}' }}
{{ '{{- end -}}' }}
EOH
  command = "chmod 0644 {{ harbor_ca_path }}"
}
