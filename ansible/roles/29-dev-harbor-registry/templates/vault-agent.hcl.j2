
pid_file = "/var/run/vault-agent.pid"

vault {
  address = "{{ vault_addr }}"
  ca_cert = "{{ vault_agent_config_dir }}/vault-ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/{{ vault_auth_path }}"
    config = {
      role_id_file_path = "{{ vault_agent_config_dir }}/approle/role_id"
      secret_id_file_path = "{{ vault_agent_config_dir }}/approle/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/tmp/vault-token"
    }
  }
}

# Server Certificate, Key & CA Bundle Template
template {
  destination = "/tmp/cert-bundle.json"
  contents = <<EOH
{{ '{{- with secret "pki/prod/issue/' ~ vault_role_name ~ '" "common_name=' ~ vault_agent_common_name ~ '" "ip_sans=' ~ advertise_ip ~ ',' ~ dev_harbor_vip ~ '" "ttl=' ~ (vault_agent_cert_ttl | default('24h')) ~ '" -}}' }}
{{ '{{ .Data | toJSON }}' }}
{{ '{{- end -}}' }}
EOH

  # Split bundle into separate standard files using jq, apply permissions, copy to nginx mount path, and trigger nginx reload
  command = "/bin/sh -c \"mkdir -p /data/harbor/secret/cert && jq -r '.certificate' /tmp/cert-bundle.json > {{ harbor_cert_path }} && jq -r '.private_key' /tmp/cert-bundle.json > {{ harbor_key_path }} && jq -r '.issuing_ca' /tmp/cert-bundle.json > {{ harbor_ca_path }} && cp {{ harbor_cert_path }} /data/harbor/secret/cert/server.crt && cp {{ harbor_key_path }} /data/harbor/secret/cert/server.key && chmod 600 {{ harbor_key_path }} /data/harbor/secret/cert/server.key && chmod 644 {{ harbor_ca_path }} /data/harbor/secret/cert/server.crt && (docker ps -q -f name=^nginx$ | grep -q . && docker exec -i nginx nginx -s reload || true)\""
}
