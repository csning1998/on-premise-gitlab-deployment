
target_clusters = {
  minio = "core-harbor-minio"
}

primary_role = "minio"

service_config = {
  "minio" = {
    role            = "minio"
    network_tier    = "minio"
    base_image_path = "../../../packer/output/base-minio/ubuntu-24-base-minio.qcow2"
    nodes = {
      "00" = { ip_suffix = 200, vcpu = 2, ram_size = 1024 }
      # Uncomment the following lines for HA setup, abide by node % 4 != 0.
      # "01" = { ip_suffix = 201, vcpu = 2, ram_size = 1024 },
      # "02" = { ip_suffix = 202, vcpu = 2, ram_size = 1024 },
      # "03" = { ip_suffix = 203, vcpu = 2, ram_size = 1024 }
    }
  }
}
