
trust_engine_config = {
  issuer_name           = "vault-issuer"
  issuer_kind           = "ClusterIssuer"
  authorized_namespaces = ["cert-manager", "harbor"]
}

cert_manager_config = {
  version   = "v1.14.0"
  namespace = "cert-manager"
}

harbor_helm_config = {
  version         = "1.18.0"
  namespace       = "harbor"
  ingress_class   = "nginx"
  tls_secret_name = "harbor-ingress-cert"
  notary_prefix   = "notary"
}

object_storage_config = {
  bucket_name = "harbor-registry"
  region      = "us-east-1"
}
