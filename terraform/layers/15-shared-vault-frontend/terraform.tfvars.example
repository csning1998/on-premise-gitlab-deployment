# IMPORTANT:
# * Dev Environment: The Private Key is injected from Terraform and write into State **for convenient**
# * Prod Environment: Terraform only reads the manually pre-injected file, where the Private Key will not be generated by Terraform.

target_clusters = { "vault" = "core-vault-frontend" }
primary_role    = "vault"

service_config = {
  "vault" = {
    role            = "vault"
    network_tier    = "default"
    base_image_path = "../../../packer/output/base-vault/ubuntu-24-base-vault.qcow2"

    nodes = {
      # Single Mode
      "00" = { ip_suffix = 200, vcpu = 2, ram_size = 512 }
      # Uncomment the following lines for HA setup, abide by node % 2 != 0.
      # "01" = { ip_suffix = 201, vcpu = 2, ram_size = 512 },
      # "02" = { ip_suffix = 202, vcpu = 2, ram_size = 512 },
    }
  }
}
