          "metrics" = { frontend_port = 9236, backend_port = 9236 }
        }
        data_disks = [
          { name_suffix = "data", capacity_gib = 100 }
        ]
      }
      "praefect" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 140
        tags       = ["with-141-praefect-patroni"]
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "proxy"   = { frontend_port = 2305, backend_port = 2305 }
          "metrics" = { frontend_port = 9652, backend_port = 9652 }
        }
      }
      "praefect-patroni" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 141
        tags       = ["with-140-praefect"]
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "rw-proxy" = { frontend_port = 5432, backend_port = 5432, health_check_type = "http", health_check_port = 8008, health_check_http_path = "/primary" }
          "api"      = { frontend_port = 8008, backend_port = 8008 }
          "etcd"     = { frontend_port = 2379, backend_port = 2379 }
          "metrics"  = { frontend_port = 9187, backend_port = 9187 }
        }
        data_disks = [{ name_suffix = "data", capacity_gib = 50 }]
      }
      "runner" = {
        provider   = "kvm"
        runtime    = "microk8s"
        cidr_index = 139
        tags       = []
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "api-server" = { frontend_port = 16443, backend_port = 16443 }
          "metrics"    = { frontend_port = 9252, backend_port = 9252 }
          "session"    = { frontend_port = 8093, backend_port = 8093 }
        }
        data_disks = [{ name_suffix = "data", capacity_gib = 50 }]
      }
    }
  },
  "harbor-bootstrapper" = {
    owner        = "devops"
    project_code = "core"
    stage        = "production"
    components = {
      "frontend" = {
        provider   = "kvm"
        runtime    = "docker"
        cidr_index = 137
        tags       = []
        ip_range   = { start_ip = 200, end_ip = 200 }
        ports = {
