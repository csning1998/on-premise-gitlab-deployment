
domain_suffix      = "iac.internal"
vault_kv_namespace = "on-premise-gitlab-deployment"

network_baseline = {
  cidr_block         = "172.16.0.0/16"
  vip_offset         = 250        # VIP always .250
  node_ip_start      = 200        # node ip from .200
  mac_prefix         = "52:54:00" # KVM/Libvirt common prefix
  global_mtu         = 1450
  global_mss         = 1360
  node_exporter_port = 9100 # Debian/Ubuntu prometheus-node-exporter package default
}

# The Single Source of Truth for the Root CA Identity
pki_settings = {
  root_ca_common_name         = "On-prem Infrastructure Root CA"
  intermediate_ca_common_name = "On-prem Infrastructure Intermediate CA"
}

/** Service Catalog Definition rules:
 * 0. name: define UNIQUE name of the service.
 *      (e.g. gitlab)
 * 1. owner: define the owner of the service
 *      (e.g. devops, secops...)
 * 2. project_code: define the project code of the service
 *      (e.g. iac, core...)
 * 3. provider: define the Terraform provider for the service
 *      (e.g. kvm, aws, gcp, azure, vmware...)
 * 4. runtime: define the runtime of the service
 *      (e.g. kubeadm, microk8s, baremetal...)
 * 5. stage: define the stage of the service
 *      (e.g. production, staging, development...)
 * 6. cidr_index: used to calculate subnet
 *      (e.g. 172.16.X.0/24)
 * 7. tags: define the tags of the service for better governance.
 *      (e.g. ["with-128-etcd", "with-127-postgres"])
 *     * Note: Services tagged `self-managed-lb` run their own HA stack. Refer to Central LB Layer for more details.
 * 8. ip_range: define the IP range of the service.
 *      (e.g. { start_ip = 200, end_ip = 220 })
 * 9. component: define the primary component role of the service. Default: "frontend".
 *      (e.g. frontend, backend, database...)
 * 10. node_groups: define global compute groups for the service.
 *      (e.g. ["master", "worker"])
 * 11. ingress: define network entrypoints and their target node_groups.
 *      - subdomains: (e.g. ["gitlab", "kas"])
 *      - node_groups: (e.g. ["master", "worker"])
 * 12. dependencies: define the external dependency of a specific component. Leave empty if no external dependency.
 *      (e.g. postgres, redis, minio...)
 *    - cidr_index: define the cidr index of the dependency.
 *    - runtime: define the runtime of the dependency.
 *    - component: define the component of the dependency.
 *    - tags: define the tags of the dependency for better governance.
 * 13. ports: define the ports of the service.
 *      (e.g. { frontend_port = 80, backend_port = 443 })
 */

service_catalog = {
  "central-lb" = {
    owner        = "devops"
    project_code = "core"
    stage        = "production"
    components = {
      "frontend" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 125
        tags       = []

        ip_range = { start_ip = 200, end_ip = 202 }
        ports = {
          "stats" = { frontend_port = 8404, backend_port = 8404 } # HAProxy Stats (Self)
        }
        ingress = {}
      }
    }
  },
  "vault" = {
    owner        = "secops"
    project_code = "core"
    stage        = "production"
    components = {
      "frontend" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 136
        tags       = []
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "api" = {
            frontend_port            = 443,
            backend_port             = 8200
            health_check_type        = "http"
            health_check_http_path   = "/v1/sys/health"
            health_check_http_expect = "rstatus (200|429)"
            health_check_ssl         = true
          }
        }
        data_disks = [{ name_suffix = "raft-data" }]
        ingress = {
          "raft" = { subdomains = ["vault"] }
        }
      }
    }
  },
  "keycloak" = {
    owner        = "secops"
    project_code = "core"
    stage        = "production"
    components = {
      "frontend" = {
        provider   = "kvm"
        runtime    = "docker"
        cidr_index = 142
        tags       = []
        ip_range   = { start_ip = 200, end_ip = 200 }
        ports = {
          "https" = {
            frontend_port     = 443,
            backend_port      = 8080,
            health_check_port = 9000,
            health_check_type = "tcp",
            health_check_ssl  = false
          }
          "mgmt" = {
            frontend_port     = 9000,
            backend_port      = 9000,
            health_check_type = "tcp",
            health_check_ssl  = false
          }

        }
        data_disks = [{ name_suffix = "data", capacity_gib = 20 }]
        ingress = {
          "frontend" = { subdomains = ["sso"] }
        }
      }
    }
  },
  "gitlab" = {
    owner        = "devops"
    project_code = "core"
    stage        = "production"
    components = {
      "frontend" = {
        provider   = "kvm"
        runtime    = "kubeadm"
        cidr_index = 126

        ip_range = { start_ip = 200, end_ip = 220 }
        ports = {
          "api-server"    = { frontend_port = 6443, backend_port = 6443 }
          "ingress-http"  = { frontend_port = 80, backend_port = 30080, send_proxy_v2 = true }
          "ingress-https" = { frontend_port = 443, backend_port = 30443, send_proxy_v2 = true }
          "gitlab-ssh"    = { frontend_port = 32022, backend_port = 32022 }
        }
        ingress = {
          "frontend" = { subdomains = ["gitlab", "kas"], node_groups = ["master", "worker"] }
          "minio"    = { subdomains = ["minio"] }
        }
      }
      "postgres" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 127
        tags       = ["with-128-etcd"]
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "rw-proxy" = { frontend_port = 5000, backend_port = 5432, health_check_type = "http", health_check_port = 8008, health_check_http_path = "/primary" }
          "ro-proxy" = { frontend_port = 5001, backend_port = 5432, health_check_type = "http", health_check_port = 8008, health_check_http_path = "/replica" }
          "api"      = { frontend_port = 8008, backend_port = 8008 }
          "stats"    = { frontend_port = 7000, backend_port = 7000 }
          "metrics"  = { frontend_port = 9187, backend_port = 9187 }
        }
        data_disks = [{ name_suffix = "data", capacity_gib = 100 }]
      }
      "etcd" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 128
        tags       = ["with-127-postgres"]
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "client" = { frontend_port = 2379, backend_port = 2379 }
        }
      }
      "redis" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 129
        tags       = []
        ip_range   = { start_ip = 200, end_ip = 202 }
        ports = {
          "main"    = { frontend_port = 6379, backend_port = 6379 }
          "metrics" = { frontend_port = 9121, backend_port = 9121 }
        }
