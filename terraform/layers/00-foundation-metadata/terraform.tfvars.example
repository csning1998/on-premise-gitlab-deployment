        ports = {
          "api"     = { frontend_port = 9000, backend_port = 9000 }
          "console" = { frontend_port = 9001, backend_port = 9001 }
        }
        data_disks = [
          { name_suffix = "drive1", capacity_gib = 10 },
          { name_suffix = "drive2", capacity_gib = 10 }
        ]
      }
      "gitaly" = {
        provider   = "kvm"
        runtime    = "baremetal"
        cidr_index = 138
        tags       = []
