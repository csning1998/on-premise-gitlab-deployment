
# Human-managed usernames merged into the generated credentials.
# Passwords are auto-generated by Terraform; only these usernames are set here.
minio_root_user     = "admin"
keycloak_admin_user = "admin"
keycloak_db_user    = "admin"
grafana_admin_user  = "admin"

# Set to false if the GitLab topology does not run Praefect.
gitlab_enable_praefect = true
