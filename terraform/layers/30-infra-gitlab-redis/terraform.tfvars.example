
primary_role = "redis"

target_clusters = {
  "redis" = "core-gitlab-redis"
}

service_config = {
  "redis" = {
    role            = "redis"
    network_tier    = "redis"
    base_image_path = "../../../packer/output/base-redis/ubuntu-24-base-redis.qcow2"

    nodes = {
      "00" = { ip_suffix = 200, vcpu = 2, ram_size = 2048 }
      # Uncomment the following lines for HA setup, abide by node % 2 != 0.
      # "01" = { ip_suffix = 201, vcpu = 2, ram_size = 2048 }
      # "02" = { ip_suffix = 202, vcpu = 2, ram_size = 2048 }
    }
  }
}

ansible_files = {
  playbook_file           = "20-provision-data-services.yaml"
  inventory_template_file = "inventory-redis-cluster.yaml.tftpl"
}
